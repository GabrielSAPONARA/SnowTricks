<h2 id="title-model" class="h2 position-absolute top-0 start-50 translate-middle-x bg-body p-3 rounded">{{ figure.name }}</h2>
<div class="row mx-0">
    {% if pictures|length > 0 %}
        <div class="col-12 px-0 top-div-popup-picture">
            <img class="img-fluid mb-5 fixed-size px-0 w-100 top-picture-popup"
                 src="{{ asset('uploads/figures/' ~ pictures[0].name) }}"
                 alt="Picture of {{ figure.name }}">

        </div>
    {% elseif videos|length > 0 %}
        <div class="col-12 px-0 mb-5">
            <iframe
                    class="w-100 top-video-popup"
                    title="Vidéo de {{ figure.name }}"
                    src="{{ videos[0].embedUrl|raw }}"
                    frameborder="0"
                    allowfullscreen
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share">
            </iframe>
        </div>
    {% else %}
        <div class="col-12 px-0 top-div-popup-picture">
            <img class="img-fluid mb-5 fixed-size px-0 w-100 top-picture-popup"
                 src="{{ asset('assets/img/snowboard_neige_figure_saut_shutterstock2.jpg') }}"
                 alt="Default snowboard picture">
        </div>
    {% endif %}
    {%  if is_granted('IS_AUTHENTICATED') %}
        <div class="col-3 col-md-2 col-xxl-1 d-flex position-absolute symbols p-0">
            <a class="container px-0 d-flex align-content-center"
               id="pencil-to-edit-figure"
               href="{{ path('app_figure_edit', {'slug' : figure.slug}) }}">
                <img class="col-12" src="{{ asset('assets/img/pencilToEdit.svg') }}"
                     alt="a pencil to edit a figure">
            </a>
            <a class="container px-0 d-flex align-content-center"
               id="dustbin-to-delete-figure"
               data-token="{{ csrf_token('delete' ~ figure.id) }}"
               href="#confirm-deletion">
                <img class="col-12" src="{{ asset('assets/img/bin.svg') }}"
                     alt="a bin to delete a figure">
            </a>
        </div>
    {% endif %}
</div>
<button class="d-grid d-md-none btn btn-primary see-medias d-flex mx-auto">
    See medias
</button>
<button class="d-none d-md-none btn btn-danger hide-medias d-flex mx-auto mb-3">
    Hide medias
</button>
<div class="container-fluid medias d-none d-md-grid">
    <div class="row d-flex flex-column flex-md-row over flex-md-nowrap justify-content-center justify-content-md-start overflow-scroll">
        {% if pictures|length > 0 %}
            {% for picture in pictures %}
                <div class="col-9 col-md-4 d-flex align-self-center p-0 mb-3 mx-md-3">
                    <img class="img-fluid rounded-3 w-100 h-100"
                         src="{{ asset('uploads/figures/' ~ picture.name) }}"
                         alt="Picture of {{ figure.name }}">
                </div>
            {% endfor %}
        {% endif %}
        {% if videos|length > 0 %}
            {% for video in videos %}
                <div class="col-9 col-md-4 d-flex align-self-center p-0 mb-3 mx-md-3">
                    <iframe
                            class="img-fluid h-100 w-100 rounded-3"
                            title="Vidéo de {{ figure.name }}"
                            src="{{ video.embedUrl|raw }}"
                            frameborder="0"
                            allowfullscreen
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share">
                    </iframe>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>
<button class="d-none d-md-none btn btn-danger hide-medias d-flex mx-auto">
    Hide medias
</button>
<div class="row w-100 d-flex justify-content-center my-5" style="max-height: 50dvh; overflow: scroll;">
    <p class="col-9">
        {{ figure.description }}
    </p>
</div>
<div class="row d-flex flex-column flex-lg-row px-5 justify-content-center">
    <p class="col-12 col-lg-4 col-xl-3 border border-dark">
        Creation date : {{ figure.creationDate|date('Y-m-d') }}
    </p>
    <p class="col-12 col-lg-4 col-xl-3 mx-lg-1 mx-xl-3 border border-dark">
        Modification date: {{ figure.dateOfLastUpdate|date('Y-m-d') }}
    </p>
    <p class="col-12 col-lg-3 col-xl-3 border border-dark">
        Group : {{ figure.group.name }}
    </p>
</div>

{%  if is_granted('IS_AUTHENTICATED') %}
    <div class="row d-flex justify-content-center mt-5">
        <div class="border-bottom border-3 border-dark col-6"></div>
    </div>

    <div class="container mt-4 mb-5">
        {{ form_start(formMessage, { 'attr' : {'class' : 'row d-flex flex-column flex-lg-row px-3 justify-content-center'}}) }}
            {{ form_widget(formMessage.content, {'attr' : {'class' : 'col-12 col-lg-8 mb-3 mb-lg-0 me-lg-3'}}) }}
        <button id="save-message" class="btn btn-primary col-12 col-lg-3">{{ button_label|default('Leave a comment') }}</button>
        {{ form_end(formMessage) }}
    </div>

{% endif %}

<div class="row d-flex justify-content-center mb-5">
    <div class="border-bottom border-3 border-dark col-6"></div>
</div>

<a class="js-message-page d-none" href="{{ path('app_message_to_one_figure', {'figureSlug' : figure.slug}) }}"></a>

<div class="container bg-light js-figure-messages" id="messages">
    {% include 'figure/_messages.html.twig' with {'messages' : messages} only %}
</div>

<div id="pagination" class="js-message-pagination d-flex justify-content-center my-3" data-max-page="{{ maxPage }}">
    {% include 'figure/_pagination.html.twig' with {'page' : page, 'maxPage' : maxPage, 'figureSlug': figureSlug} only %}
</div>

