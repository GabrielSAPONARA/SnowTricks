{% for message in messages %}
    <div class="row my-5 mx-3 message-row">
        <div class="col-12 col-sm-3 col-lg-2 d-flex flex-sm-column">
            <div class="col-3 col-sm-12">
                {% if message.user.avatar %}
                    <img class="col-12 rounded-circle px-0"
                         src="{{ asset('uploads/avatars/' ~ message.user.avatar) }}"
                         alt="Avatar of {{ message.user.username }}">
                {% else %}
                    <img class="col-12 col-lg-7 rounded-circle px-0"
                         src="{{ asset('assets/img/defaultUserAvatar.png') }}"
                         alt="Avatar of {{ message.user.username }}">
                {% endif %}
                <p class="m-0 px-0">
                    {{ message.user.username }}
                </p>
            </div>
            <div class="d-flex align-items-end">
                {{ message.dateOfLastUpdate|date("d/m/Y H:i:s") }}
            </div>
        </div>
        <div class="col-12 col-sm-9 col-lg-10 border border-3 border-dark h-100 overflow-scroll">
            {{ message.content }}
        </div>
    </div>
{% endfor %}
